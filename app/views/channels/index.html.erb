<section>
  <h2 class="text-2xl font-bold mb-4">Channels</h2>
  <div class="mb-4">
    <%= search_form_for(@channel_q, url: channels_path, as: :channel_q, html: { class: "flex" }) do |form| %>
      <%= form.search_field(:title_or_description_or_site_url_or_feed_url_cont, placeholder: "Search Channels", class: "flex-1 py-1.5 px-2.5 text-sm border border-gray-300 rounded-l-md focus:outline-none focus:ring-1 focus:ring-[#3d8bcd] focus:border-[#3d8bcd]") %>
      <%= button_tag type: "submit", class: "px-2 border border-l-0 border-gray-300 rounded-r-md hover:bg-gray-50 cursor-pointer" do %>
        <span class="material-symbols-outlined !m-0 text-gray-500 text-[20px]">search</span>
      <% end %>
    <% end %>
  </div>
  <%= paginate(@channels) %>
  <%= render(partial: "channels/grid_cards", locals: { channels: @channels }) %>
  <%= paginate(@channels) %>
</section>
