<aside class="hidden md:flex md:flex-col md:w-60 md:fixed md:inset-y-0 md:left-0 bg-white border-r border-gray-200 z-40">
  <%# Logo %>
  <div class="flex items-center h-16 px-5 shrink-0">
    <%= link_to image_tag("logo.svg", class: "w-[120px] h-auto"), root_path, class: "leading-none" %>
  </div>

  <%# Main Navigation %>
  <nav class="flex-1 overflow-y-auto px-3 py-2">
    <ul class="space-y-0.5">
      <% if logged_in? %>
        <%= render 'layouts/sidebar/unreads_menu' %>
        <%= render 'layouts/sidebar/pawprints_menu' %>
      <% end %>
      <%= render 'layouts/sidebar/explore_menu' %>
    </ul>
  </nav>

  <%# Search or Add Channel trigger %>
  <% if logged_in? %>
    <div class="px-3 mb-3">
      <label for="channel-registration-form" class="flex items-center gap-2 w-full px-2.5 py-2 text-sm text-gray-400 border border-gray-300 rounded-md hover:border-gray-400 hover:bg-gray-50 cursor-pointer transition-colors">
        <span class="material-symbols-outlined !m-0 text-[18px]">search</span>
        <span>Search or Add Channel</span>
      </label>
    </div>
  <% end %>

  <%# Footer %>
  <div class="shrink-0 border-t border-gray-200 px-3 py-3">
    <% if logged_in? %>
      <% if current_user.admin? %>
        <div class="mb-2">
          <%= link_to(admin_path, class: "flex items-center gap-2.5 px-2.5 py-2 rounded-md text-sm text-gray-700 hover:bg-gray-100 transition-colors") do %>
            <span class="material-symbols-outlined !m-0 text-[20px]">admin_panel_settings</span>
            <span>Admin</span>
          <% end %>
        </div>
      <% end %>

      <div data-controller="dropdown" class="relative">
        <button data-action="click->dropdown#toggle" class="w-full flex items-center gap-2.5 px-2.5 py-2 rounded-md hover:bg-gray-100 transition-colors">
          <%= user_avatar_tag(current_user, size: :xs) %>
          <span class="text-sm text-gray-700 truncate flex-1 text-left"><%= current_user.name %></span>
          <span data-dropdown-target="icon" class="material-symbols-outlined !m-0 text-[20px] text-gray-400">add</span>
        </button>

        <%# Dropup Menu %>
        <div data-dropdown-target="menu" class="hidden absolute bottom-full left-0 right-0 mb-2 bg-white border border-gray-200 rounded-md shadow-lg py-1">
          <%= link_to(user_path(user_name: current_user.name), class: "flex items-center gap-2.5 px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 transition-colors") do %>
            <span class="material-symbols-outlined !m-0 text-[20px]">account_circle</span>
            <span>My Page</span>
          <% end %>
          <%= link_to(my_path, class: "flex items-center gap-2.5 px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 transition-colors") do %>
            <span class="material-symbols-outlined !m-0 text-[20px]">settings</span>
            <span>Settings</span>
          <% end %>
          <%= link_to(guides_path, class: "flex items-center gap-2.5 px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 transition-colors") do %>
            <span class="material-symbols-outlined !m-0 text-[20px]">info</span>
            <span>Guides</span>
          <% end %>
          <div class="border-t border-gray-200 my-1"></div>
          <%= link_to(about_path, class: "flex items-center gap-2.5 px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 transition-colors") do %>
            <span class="material-symbols-outlined !m-0 text-[20px]">help</span>
            <span>About</span>
          <% end %>
          <%= link_to(terms_path, class: "flex items-center gap-2.5 px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 transition-colors") do %>
            <span class="material-symbols-outlined !m-0 text-[20px]">gavel</span>
            <span>Terms</span>
          <% end %>
          <%= link_to(privacy_path, class: "flex items-center gap-2.5 px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 transition-colors") do %>
            <span class="material-symbols-outlined !m-0 text-[20px]">shield</span>
            <span>Privacy</span>
          <% end %>
          <div class="border-t border-gray-200 my-1"></div>
          <%= link_to(session_path, data: { turbo_method: :delete }, class: "flex items-center gap-2.5 px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 transition-colors") do %>
            <span class="material-symbols-outlined !m-0 text-[20px]">logout</span>
            <span>Logout</span>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="px-2.5">
        <%= link_to "Login", login_path, class: "inline-flex items-center justify-center w-full px-4 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50" %>
      </div>
      <div class="flex justify-center items-center gap-2 mt-3 text-xs text-gray-400">
        <%= link_to "About", about_path, class: "hover:text-gray-600" %>
        <span>·</span>
        <%= link_to "Terms", terms_path, class: "hover:text-gray-600" %>
        <span>·</span>
        <%= link_to "Privacy", privacy_path, class: "hover:text-gray-600" %>
      </div>
    <% end %>
    <p class="text-center text-xs text-gray-400 mt-2">© rururu</p>
  </div>
</aside>
