<aside class="hidden md:flex md:flex-col md:w-60 md:fixed md:inset-y-0 md:left-0 bg-white border-r border-gray-200 z-40">
  <%# Logo %>
  <div class="flex items-center h-16 px-5 shrink-0">
    <%= link_to image_tag("logo.svg", class: "w-[120px] h-auto"), root_path, class: "leading-none" %>
  </div>

  <%# Search %>
  <div class="px-5 mb-2">
    <%= search_form_for((@channel_q || Channel.ransack), url: channels_path, as: :channel_q, html: { class: "flex" }) do |form| %>
      <%= form.search_field(:title_or_description_or_site_url_or_feed_url_cont, placeholder: "Search Channels", class: "w-full py-1.5 px-2.5 text-sm border border-gray-300 rounded-l-md focus:outline-none focus:ring-1 focus:ring-[#3d8bcd] focus:border-[#3d8bcd]") %>
      <%= button_tag type: "submit", class: "px-2 border border-l-0 border-gray-300 rounded-r-md hover:bg-gray-50 cursor-pointer" do %>
        <span class="material-symbols-outlined !m-0 text-gray-500 text-[20px]">search</span>
      <% end %>
    <% end %>
  </div>

  <%# Main Navigation %>
  <nav class="flex-1 overflow-y-auto px-3 py-2">
    <ul class="space-y-0.5">
      <% if logged_in? %>
      <%# Pawprints with submenu %>
      <li>
        <div class="flex items-center gap-2.5 px-2.5 py-2 text-sm text-gray-700 font-medium">
          <span class="material-symbols-outlined !m-0 !text-[16px]"><%= image_tag("icon-pawprints-b.svg", alt: "pawprints", loading: "lazy", width: 16, height: 16) %></span>
          <span>Pawprints</span>
        </div>
        <ul class="ml-4 space-y-0.5">
          <li>
            <%= link_to(pawprints_path(scope: "all"), class: "px-2.5 py-2 rounded-md text-sm text-gray-600 hover:bg-gray-100 transition-colors block") do %>
              <span class="text-gray-400 mr-1.5">•</span>All
            <% end %>
          </li>
          <li>
            <%= link_to(pawprints_path(scope: "my"), class: "px-2.5 py-2 rounded-md text-sm text-gray-600 hover:bg-gray-100 transition-colors block") do %>
              <span class="text-gray-400 mr-1.5">•</span>My
            <% end %>
          </li>
          <li>
            <%= link_to(pawprints_path(scope: "to_me"), class: "px-2.5 py-2 rounded-md text-sm text-gray-600 hover:bg-gray-100 transition-colors block") do %>
              <span class="text-gray-400 mr-1.5">•</span>To me
            <% end %>
          </li>
        </ul>
      </li>

      <%# Unreads with submenu %>
      <li>
        <div class="flex items-center gap-2.5 px-2.5 py-2 text-sm text-gray-700 font-medium">
          <span class="material-symbols-outlined !m-0 !text-[16px]">inbox</span>
          <span>Unreads</span>
        </div>
        <ul class="ml-4 space-y-0.5">
          <li>
            <%= link_to(unreads_path, class: "px-2.5 py-2 rounded-md text-sm text-gray-600 hover:bg-gray-100 transition-colors block") do %>
              <span class="text-gray-400 mr-1.5">•</span>All
            <% end %>
          </li>
          <% current_user.subscription_tags.joins(:subscriptions).distinct.ordered.each do |tag| %>
            <li>
              <%= link_to(unreads_path(subscription_tag_id: tag.id), class: "px-2.5 py-2 rounded-md text-sm text-gray-600 hover:bg-gray-100 transition-colors block") do %>
                <span class="text-gray-400 mr-1.5">•</span><%= tag.name %>
              <% end %>
            </li>
          <% end %>
        </ul>
      </li>

      <%# Explore with submenu %>
      <li>
        <div class="flex items-center gap-2.5 px-2.5 py-2 text-sm text-gray-700 font-medium">
          <span class="material-symbols-outlined !m-0 !text-[16px]">explore</span>
          <span>Explore</span>
        </div>
        <ul class="ml-4 space-y-0.5">
          <li>
            <%= link_to(channels_path, class: "px-2.5 py-2 rounded-md text-sm text-gray-600 hover:bg-gray-100 transition-colors block") do %>
              <span class="text-gray-400 mr-1.5">•</span>Channels
            <% end %>
          </li>
          <li>
            <%= link_to(items_path, class: "px-2.5 py-2 rounded-md text-sm text-gray-600 hover:bg-gray-100 transition-colors block") do %>
              <span class="text-gray-400 mr-1.5">•</span>Items
            <% end %>
          </li>
          <li>
            <%= link_to(channel_groups_path, class: "px-2.5 py-2 rounded-md text-sm text-gray-600 hover:bg-gray-100 transition-colors block") do %>
              <span class="text-gray-400 mr-1.5">•</span>Channel Groups
            <% end %>
          </li>
        </ul>
      </li>
      <% end %>
  </nav>

  <%# Footer %>
  <div class="shrink-0 border-t border-gray-200 px-3 py-3">
    <% if logged_in? %>
      <% if current_user.admin? %>
        <div class="mb-2">
          <%= link_to(admin_path, class: "flex items-center gap-2.5 px-2.5 py-2 rounded-md text-sm text-gray-700 hover:bg-gray-100 transition-colors") do %>
            <span class="material-symbols-outlined !m-0 text-[20px]">admin_panel_settings</span>
            <span>Admin</span>
          <% end %>
        </div>
      <% end %>

      <div data-controller="dropdown" class="relative">
        <button data-action="click->dropdown#toggle" class="w-full flex items-center gap-2.5 px-2.5 py-2 rounded-md hover:bg-gray-100 transition-colors">
          <%= user_avatar_tag(current_user, size: :xs) %>
          <span class="text-sm text-gray-700 truncate flex-1 text-left"><%= current_user.name %></span>
          <span class="material-symbols-outlined !m-0 text-[20px] text-gray-400">expand_more</span>
        </button>

        <%# Dropup Menu %>
        <div data-dropdown-target="menu" class="hidden absolute bottom-full left-0 right-0 mb-2 bg-white border border-gray-200 rounded-md shadow-lg py-1">
          <%= link_to(user_path(user_name: current_user.name), class: "flex items-center gap-2.5 px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 transition-colors") do %>
            <span class="material-symbols-outlined !m-0 text-[20px]">account_circle</span>
            <span>My Page</span>
          <% end %>
          <%= link_to(my_path, class: "flex items-center gap-2.5 px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 transition-colors") do %>
            <span class="material-symbols-outlined !m-0 text-[20px]">settings</span>
            <span>Settings</span>
          <% end %>
          <%= link_to(guides_path, class: "flex items-center gap-2.5 px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 transition-colors") do %>
            <span class="material-symbols-outlined !m-0 text-[20px]">info</span>
            <span>Guides</span>
          <% end %>
          <div class="border-t border-gray-200 my-1"></div>
          <%= link_to(about_path, class: "flex items-center gap-2.5 px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 transition-colors") do %>
            <span class="material-symbols-outlined !m-0 text-[20px]">help</span>
            <span>About</span>
          <% end %>
          <%= link_to(terms_path, class: "flex items-center gap-2.5 px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 transition-colors") do %>
            <span class="material-symbols-outlined !m-0 text-[20px]">gavel</span>
            <span>Terms</span>
          <% end %>
          <%= link_to(privacy_path, class: "flex items-center gap-2.5 px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 transition-colors") do %>
            <span class="material-symbols-outlined !m-0 text-[20px]">shield</span>
            <span>Privacy</span>
          <% end %>
          <div class="border-t border-gray-200 my-1"></div>
          <%= link_to(session_path, data: { turbo_method: :delete }, class: "flex items-center gap-2.5 px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 transition-colors") do %>
            <span class="material-symbols-outlined !m-0 text-[20px]">logout</span>
            <span>Logout</span>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="px-2.5">
        <%= link_to "Login", login_path, class: "inline-flex items-center justify-center w-full px-4 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50" %>
      </div>
    <% end %>
    <p class="text-center text-xs text-gray-400 mt-2">© rururu</p>
  </div>
</aside>
