<aside class="hidden md:flex md:flex-col md:w-60 md:fixed md:inset-y-0 md:left-0 bg-white border-r border-gray-200 z-40">
  <%# Logo %>
  <div class="flex items-center h-16 px-5 shrink-0">
    <%= link_to image_tag("logo.svg", class: "w-[120px] h-auto"), root_path, class: "leading-none" %>
  </div>

  <%# Search %>
  <div class="px-5 mb-2">
    <%= search_form_for((@channel_q || Channel.ransack), url: channels_path, as: :channel_q, html: { class: "flex" }) do |form| %>
      <%= form.search_field(:title_or_description_or_site_url_or_feed_url_cont, placeholder: "Search Channels", class: "w-full py-1.5 px-2.5 text-sm border border-gray-300 rounded-l-md focus:outline-none focus:ring-1 focus:ring-[#3d8bcd] focus:border-[#3d8bcd]") %>
      <%= button_tag type: "submit", class: "px-2 border border-l-0 border-gray-300 rounded-r-md hover:bg-gray-50 cursor-pointer" do %>
        <span class="material-symbols-outlined !m-0 text-gray-500 text-[20px]">search</span>
      <% end %>
    <% end %>
  </div>

  <%# Main Navigation %>
  <nav class="flex-1 overflow-y-auto px-3 py-2">
    <ul class="space-y-0.5">
      <% if logged_in? %>
      <%# Pawprints with submenu %>
      <li>
        <div class="flex items-center gap-1.5 px-2.5 py-2 text-sm text-gray-700 font-medium">
          <span class="material-symbols-outlined !m-0 !text-[16px]"><%= image_tag("icon-pawprints-b.svg", alt: "pawprints", loading: "lazy", width: 16, height: 16) %></span>
          <span>Pawprints</span>
        </div>
        <ul class="ml-2 mr-2 space-y-0.5">
          <%
            pawprints_all_active = current_page?(pawprints_path) && params[:scope].blank?
          %>
          <li>
            <%= link_to(pawprints_path, class: "px-2 py-1.5 rounded-md text-sm transition-colors flex items-center #{pawprints_all_active ? "bg-blue-50 text-blue-700" : "text-gray-600 hover:bg-gray-100"}") do %>
              <span class="mr-1.5 shrink-0 #{pawprints_all_active ? "text-blue-400" : "text-gray-400"}">•</span>
              <span class="truncate">All</span>
            <% end %>
          </li>
          <li>
            <%= link_to(pawprints_path(scope: "my"), class: "px-2 py-1.5 rounded-md text-sm transition-colors flex items-center #{current_page?(pawprints_path(scope: "my")) ? "bg-blue-50 text-blue-700" : "text-gray-600 hover:bg-gray-100"}") do %>
              <span class="mr-1.5 shrink-0 #{current_page?(pawprints_path(scope: "my")) ? "text-blue-400" : "text-gray-400"}">•</span>
              <span class="truncate">My</span>
            <% end %>
          </li>
          <li>
            <%= link_to(pawprints_path(scope: "to_me"), class: "px-2 py-1.5 rounded-md text-sm transition-colors flex items-center #{current_page?(pawprints_path(scope: "to_me")) ? "bg-blue-50 text-blue-700" : "text-gray-600 hover:bg-gray-100"}") do %>
              <span class="mr-1.5 shrink-0 #{current_page?(pawprints_path(scope: "to_me")) ? "text-blue-400" : "text-gray-400"}">•</span>
              <span class="truncate">To me</span>
            <% end %>
          </li>
        </ul>
      </li>

      <%# Unreads with submenu %>
      <li>
        <div class="flex items-center gap-1.5 px-2.5 py-2 text-sm text-gray-700 font-medium">
          <span class="material-symbols-outlined !m-0 !text-[16px]">inbox</span>
          <span>Unreads</span>
        </div>
        <ul class="ml-2 mr-2 space-y-0.5">
          <%
            # Unreadsページにいるかどうかをパスで判定
            on_unreads_page = request.path == unreads_path
            unreads_all_active = on_unreads_page && params[:subscription_tag_id].blank? && params[:channel_group_id].blank?
          %>
          <li>
            <%= link_to(unreads_path, class: "px-2 py-1.5 rounded-md text-sm transition-colors flex items-center #{unreads_all_active ? "bg-blue-50 text-blue-700" : "text-gray-600 hover:bg-gray-100"}") do %>
              <span class="mr-1.5 shrink-0 #{unreads_all_active ? "text-blue-400" : "text-gray-400"}">•</span>
              <span class="truncate">All</span>
            <% end %>
          </li>
          <% current_user.subscription_tags.joins(:subscriptions).distinct.ordered.each do |tag| %>
            <%
              tag_active = on_unreads_page && params[:subscription_tag_id].to_s == tag.id.to_s
            %>
            <li>
              <%= link_to(unreads_path(subscription_tag_id: tag.id), class: "px-2 py-1.5 rounded-md text-sm transition-colors flex items-center #{tag_active ? "bg-blue-50 text-blue-700" : "text-gray-600 hover:bg-gray-100"}") do %>
                <span class="mr-1.5 shrink-0 #{tag_active ? "text-blue-400" : "text-gray-400"}">•</span>
                <span class="truncate"><%= tag.name %></span>
              <% end %>
            </li>
          <% end %>
          <% current_user.own_and_joined_channel_groups.order(id: :desc).each do |channel_group| %>
            <%
              group_active = on_unreads_page && params[:channel_group_id].to_s == channel_group.id.to_s
            %>
            <li>
              <%= link_to(unreads_path(channel_group_id: channel_group.id), class: "px-2 py-1.5 rounded-md text-sm transition-colors flex items-center #{group_active ? "bg-blue-50 text-blue-700" : "text-gray-600 hover:bg-gray-100"}") do %>
                <span class="mr-1.5 shrink-0 #{group_active ? "text-blue-400" : "text-gray-400"}">•</span>
                <span class="truncate"><%= channel_group.name %></span>
              <% end %>
            </li>
          <% end %>
        </ul>
      </li>

      <%# Explore with submenu %>
      <li>
        <div class="flex items-center gap-1.5 px-2.5 py-2 text-sm text-gray-700 font-medium">
          <span class="material-symbols-outlined !m-0 !text-[16px]">explore</span>
          <span>Explore</span>
        </div>
        <ul class="ml-2 mr-2 space-y-0.5">
          <li>
            <%= link_to(channels_path, class: "px-2 py-1.5 rounded-md text-sm transition-colors flex items-center #{current_page?(channels_path) ? "bg-blue-50 text-blue-700" : "text-gray-600 hover:bg-gray-100"}") do %>
              <span class="mr-1.5 shrink-0 #{current_page?(channels_path) ? "text-blue-400" : "text-gray-400"}">•</span>
              <span class="truncate">Channels</span>
            <% end %>
          </li>
          <li>
            <%= link_to(items_path, class: "px-2 py-1.5 rounded-md text-sm transition-colors flex items-center #{current_page?(items_path) ? "bg-blue-50 text-blue-700" : "text-gray-600 hover:bg-gray-100"}") do %>
              <span class="mr-1.5 shrink-0 #{current_page?(items_path) ? "text-blue-400" : "text-gray-400"}">•</span>
              <span class="truncate">Items</span>
            <% end %>
          </li>
          <li>
            <%= link_to(channel_groups_path, class: "px-2 py-1.5 rounded-md text-sm transition-colors flex items-center #{current_page?(channel_groups_path) ? "bg-blue-50 text-blue-700" : "text-gray-600 hover:bg-gray-100"}") do %>
              <span class="mr-1.5 shrink-0 #{current_page?(channel_groups_path) ? "text-blue-400" : "text-gray-400"}">•</span>
              <span class="truncate">Channel Groups</span>
            <% end %>
          </li>
        </ul>
      </li>
      <% end %>
  </nav>

  <%# Footer %>
  <div class="shrink-0 border-t border-gray-200 px-3 py-3">
    <% if logged_in? %>
      <% if current_user.admin? %>
        <div class="mb-2">
          <%= link_to(admin_path, class: "flex items-center gap-2.5 px-2.5 py-2 rounded-md text-sm text-gray-700 hover:bg-gray-100 transition-colors") do %>
            <span class="material-symbols-outlined !m-0 text-[20px]">admin_panel_settings</span>
            <span>Admin</span>
          <% end %>
        </div>
      <% end %>

      <div data-controller="dropdown" class="relative">
        <button data-action="click->dropdown#toggle" class="w-full flex items-center gap-2.5 px-2.5 py-2 rounded-md hover:bg-gray-100 transition-colors">
          <%= user_avatar_tag(current_user, size: :xs) %>
          <span class="text-sm text-gray-700 truncate flex-1 text-left"><%= current_user.name %></span>
          <span data-dropdown-target="icon" class="material-symbols-outlined !m-0 text-[20px] text-gray-400">add</span>
        </button>

        <%# Dropup Menu %>
        <div data-dropdown-target="menu" class="hidden absolute bottom-full left-0 right-0 mb-2 bg-white border border-gray-200 rounded-md shadow-lg py-1">
          <%= link_to(user_path(user_name: current_user.name), class: "flex items-center gap-2.5 px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 transition-colors") do %>
            <span class="material-symbols-outlined !m-0 text-[20px]">account_circle</span>
            <span>My Page</span>
          <% end %>
          <%= link_to(my_path, class: "flex items-center gap-2.5 px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 transition-colors") do %>
            <span class="material-symbols-outlined !m-0 text-[20px]">settings</span>
            <span>Settings</span>
          <% end %>
          <%= link_to(guides_path, class: "flex items-center gap-2.5 px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 transition-colors") do %>
            <span class="material-symbols-outlined !m-0 text-[20px]">info</span>
            <span>Guides</span>
          <% end %>
          <div class="border-t border-gray-200 my-1"></div>
          <%= link_to(about_path, class: "flex items-center gap-2.5 px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 transition-colors") do %>
            <span class="material-symbols-outlined !m-0 text-[20px]">help</span>
            <span>About</span>
          <% end %>
          <%= link_to(terms_path, class: "flex items-center gap-2.5 px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 transition-colors") do %>
            <span class="material-symbols-outlined !m-0 text-[20px]">gavel</span>
            <span>Terms</span>
          <% end %>
          <%= link_to(privacy_path, class: "flex items-center gap-2.5 px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 transition-colors") do %>
            <span class="material-symbols-outlined !m-0 text-[20px]">shield</span>
            <span>Privacy</span>
          <% end %>
          <div class="border-t border-gray-200 my-1"></div>
          <%= link_to(session_path, data: { turbo_method: :delete }, class: "flex items-center gap-2.5 px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 transition-colors") do %>
            <span class="material-symbols-outlined !m-0 text-[20px]">logout</span>
            <span>Logout</span>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="px-2.5">
        <%= link_to "Login", login_path, class: "inline-flex items-center justify-center w-full px-4 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50" %>
      </div>
    <% end %>
    <p class="text-center text-xs text-gray-400 mt-2">© rururu</p>
  </div>
</aside>
